  "repository": {
    "type": "git",
    "url": "git+https://github.com/DreamLongYT/pkg-scaffold.git"
  },
  "bugs": {
    "url": "https://github.com/DreamLongYT/pkg-scaffold/issues"
  },
  "homepage": "https://dreamlongyt.github.io/pkg-scaffold/",
  "dependencies": {
    "ansis": "^3.0.0",
    "commander": "^12.0.0",
    "enhanced-resolve": "^5.16.0",
    "execa": "^8.0.1",
    "oxc-parser": "^0.135.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "vitepress": "^1.6.4",
    "vue": ">=3.5.0"
  },
