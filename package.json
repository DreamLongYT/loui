{
  "name": "pkg-scaffold",
  "version": "3.3.8",
  "description": "The Ultimate Enterprise Codebase Janitor. Faster than Knip with OXC integration, type-aware analysis, and automated structural healing. Fully standalone - solving what Knip cannot.",
  "type": "module",
  "main": "index.js",
  "bin": {
    "pkg-scaffold": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "pkg-scaffold:run": "npx pkg-scaffold --fix",
    "test": "echo \"Error: no test specified\" && exit 0",
    "test:stability": "npm run test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs && cp docs/sitemap.xml docs/.vitepress/dist/ && cp docs/robots.txt docs/.vitepress/dist && cp logo.png docs/.vitepress/dist",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "analysis",
    "analyze",
    "ast",
    "automation",
    "cli",
    "gui",
    "class",
    "dead-code",
    "dependencies",
    "dependency-analysis",
    "dependency-audit",
    "detect",
    "devDependencies",
    "duplicate",
    "entropy",
    "enum",
    "export",
    "files",
    "find",
    "ghost-dependencies",
    "javascript",
    "maintenance",
    "members",
    "missing",
    "missing-imports",
    "monorepo",
    "namespace",
    "oxc",
    "package.json",
    "packages",
    "scan",
    "security",
    "secret-scanner",
    "secrets",
    "hardcoded-secrets",
    "credentials",
    "audit",
    "structural-healing",
    "setup",
    "type",
    "types",
    "typescript",
    "unreferenced",
    "unresolved",
    "unused",
    "unused-packages",
    "workspace"
  ],
