{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "./",
    "paths": {
      "@core/*": ["src/core/*"],
      "@utils/*": ["src/utils/*"],
      "@services/*": ["src/services/*"],
      "@hooks/*": ["src/hooks/*"],
      "@components/*": ["src/components/*"],
      "@plugins/*": ["src/plugins/*"],
      "@adapters/*": ["src/adapters/*"],
      "@models/*": ["src/models/*"],
      "@store/*": ["src/store/*"],
      "@types/*": ["src/types/*"],
      "@config/*": ["src/config/*"],
      "@legacy/*": ["src/legacy/*"],
      "@dynamic/*": ["src/dynamic/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
